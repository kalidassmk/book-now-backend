# BookNow python-engine — environment variables
# Copy this file to .env in the python-engine/ directory and fill in
# your values. Settings here override the defaults in
# booknow/config/settings.py.
#
# Loading order: dashboard/.env first, then python-engine/.env
# (python-engine/.env wins on conflicts). This means you can keep
# Binance credentials in one place and only override engine-specific
# flags here.

# ── Binance credentials (required for live mode) ────────────────────
# Get these from https://www.binance.com/en/my/settings/api-management
# Spot trading permission only — never enable margin/futures here.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# ── Redis (must match dashboard's REDIS_HOST/REDIS_PORT) ────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# ── Engine run-mode toggles ─────────────────────────────────────────

# When false, TradeExecutor logs intended orders but never places
# them on Binance. Always start a new install in paper mode.
BOOKNOW_LIVE_MODE=false

# HTTP API port (the dashboard's server.js proxies to this).
BOOKNOW_HTTP_PORT=8083

# DEBUG-level logging (default INFO). Verbose; only enable when
# diagnosing a specific issue.
BOOKNOW_DEBUG=false

# ── Sentiment-engine supervisor ─────────────────────────────────────

# When true, the engine spawns the 10 sentiment-engine subprocesses
# (Fee Intelligence, Symbol Sync, Market Scanner, Fast Move Analyzer,
# Fast Scalper, Profit Analyzer, Pattern Recorder, Pattern Matcher,
# Profit Trend, Virtual Scalper) under one Python process via the
# supervisor. Set to false to run the trading core alone.
BOOKNOW_SENTIMENT_ENABLED=true

# Override the supervisor's working directory if you've moved the
# sentiment scripts. Default: booknow/sentiment/scripts (in-tree).
# BOOKNOW_SENTIMENT_DIR=
